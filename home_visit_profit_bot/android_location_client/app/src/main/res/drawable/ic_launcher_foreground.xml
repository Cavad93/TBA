<?xml version="1.0" encoding="utf-8"?>
<!-- Передний слой: белый пин-точка на карте + вырезанная галочка «стоит».
     Контент удержан в безопасной зоне адаптивной иконки (центр 108x108). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Пин (белая капля). Уменьшен и с большим отступом — не «приплюснут». -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,28 C43.5,28 35,36 35,47 C35,60 54,77 54,77 C54,77 73,60 73,47 C73,36 64.5,28 54,28 Z" />
    <!-- Галочка внутри головки пина, цвет фона — читается как вырез. -->
    <path
        android:strokeColor="#12A150"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M45,47 L51.5,54 L64,39" />
</vector>
