# Пример .env для production. Скопируйте в корень home_visit_profit_bot/.env
# и подставьте свой ключ.
#
#   cp deploy/env.production.example .env
#   # сгенерировать ключ: python -c "import secrets; print(secrets.token_urlsafe(48))"

DATABASE_PATH=data.sqlite3
LOCATION_API_ENABLED=true

# ВАЖНО: в production backend слушает ТОЛЬКО localhost.
# Наружу (на 443/HTTPS) смотрит Caddy, а не Python напрямую.
LOCATION_API_HOST=127.0.0.1
LOCATION_API_PORT=8088

# Общий ключ авторизации приложения (тот же вводится в настройках приложения).
# Держите его длинным и случайным; при утечке — смените здесь и в приложении.
LOCATION_API_KEY=replace_with_long_random_key
