# Caddyfile — сайт + API с автоматическим HTTPS (Let's Encrypt).
#
# Caddy сам получает и продлевает TLS-сертификаты для указанных имён.
#
# Требования:
#   * A-записи vizitorkrut.ru, www.vizitorkrut.ru, api.vizitorkrut.ru → IP этого сервера;
#   * порты 80 и 443 открыты в firewall;
#   * backend (python -m app.main) слушает 127.0.0.1:8088 (см. env.production.example).

# --- Лендинг (статический сайт) на корневом домене ---
vizitorkrut.ru, www.vizitorkrut.ru {
	encode zstd gzip

	# Папка со статикой. Путь укажите под свой сервер (см. DEPLOYMENT.md).
	root * /opt/tba/home_visit_profit_bot/deploy/site
	file_server

	# www.vizitorkrut.ru → без www.
	@www host www.vizitorkrut.ru
	redir @www https://vizitorkrut.ru{uri} permanent

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		-Server
	}
}

# --- Backend (API) на поддомене api.* — сюда ходит Android-приложение ---
api.vizitorkrut.ru {
	encode zstd gzip

	# Единственный публичный вход к backend, который наружу НЕ смотрит.
	# Токен (Authorization: Bearer ...) приложение шлёт как есть — Caddy его не трогает.
	reverse_proxy 127.0.0.1:8088 {
		# Пассивный health-check: если backend отвечает не 2xx на /api/health,
		# Caddy временно пометит апстрим нездоровым.
		health_uri /api/health
		health_interval 30s
		health_timeout 5s
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		-Server
	}
}
